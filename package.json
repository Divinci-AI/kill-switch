{
  "name": "cloud-cost-guardian",
  "version": "0.1.0",
  "private": true,
  "description": "Monitor cloud spending, auto-kill runaway services, protect your infrastructure. Born from a $91K Cloudflare bill.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AiExpanse/cloud-cost-guardian"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "cd packages/api && npm test",
    "dev:api": "cd packages/api && npm run dev",
    "dev:web": "cd packages/web && npm run dev",
    "build:api": "cd packages/api && npm run build",
    "build:web": "cd packages/web && npm run build",
    "deploy:api": "cd packages/api && npm run deploy",
    "deploy:kill-switch": "cd packages/kill-switch-cf && npm run deploy",
    "deploy:agent": "cd packages/agent && npm run deploy"
  }
}
